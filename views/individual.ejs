      <%layout("layouts/boilerplate")%>
      
      <div class="individual-data offset-4">
        <h1><%=list.title%></h1>
         <div class="card" style="width: 30rem;">
             <div class="show-image">
        <img class="card-img-top" src="<%=list.image.url%>" alt="Card image cap">
        </div>
        <div class="card-body">
            <p class="card-title"><%=list.title%></p>
            <br>
            <p class="card-text">owned by <%=list.owner.username%></p><br>
            <p class="card-text"><%=list.description%></p>
            <p class="card-text">&#8377;<%=list.price.toLocaleString("en-IN")%></p>
            <p class="card-text"><%=list.country %></p>
             <p class="card-text"><%=list.location %></p>
             <br>
            <% if(curruser && list.owner._id.equals(curruser._id)){%>
             <div class="btns-edit-delete ">
                <form action="/index/edit/<%=list._id %>" class="btns-edit" method="get">
                    <button>Edit</button>
                </form>
                <form action="/index/<%=list._id %>?_method=delete" class="btns-delete" method="post">
                    <button>Delete</button>
                </form>
                <br>
                <br>
                
             </div>
             <% }%>
             
            <br>
            <br>
            <% if(loggedin) {%>
             <div>
                <h3>Leave your reviews</h3>
                <form action="/index/<%=list._id%>/review" method="post" class="needs-validation" novalidate>

                    <label for="content" class="form-label">content</label>
                    <input id="content" type="String" name="review[content]" class="form-control"required >
                   <div class="mb-3">
    <fieldset class="starability-slot">
                    <legend>First rating:</legend>
                    <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="0" checked aria-label="No rating." />
                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                    <label for="first-rate1" title="Terrible">1 star</label>
                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                    <label for="first-rate2" title="Not good">2 stars</label>
                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                    <label for="first-rate3" title="Average">3 stars</label>
                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
            <br>
            <label for="rating" class="form-label">Ratings</label>
</div>
                


                    <button class="add-btn">Submit review</button><br>
                </form>
             </div>
            <%}%>
             <hr>
             <h3 class="text-center mb-4">All Reviews</h3>

<div class="row">
    <% for (let review of list.reviews) { %>
        <div class="col-md-6 mb-6 ">
            <div class="card card-review shadow-sm mt-3">
                <div class="card-body">
                    <p class="card-text"><b>@<%= review.author.username %></b></p><br>
                    <p class="card-text"><%= review.content %></p>
                </div>
                <div class="card-footer bg-white border-0">
                    <p class="starability-result" data-rating=<%= review.rating %>>
                        Rated: 3 stars
                    </p>
                    <br><br>
                    <form action="/index/<%=list._id%>/review/<%=review._id %>?_method=DELETE" method="POST">
                        <button class="btn btn-outline-dark">Delete  review</button><br>
                    </form>
                    
                </div>
            </div>
        </div>
    <% } %>
</div>       
             

        </div>
        </div>
      </div>

     
    
    
